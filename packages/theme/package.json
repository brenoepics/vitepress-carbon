{
  "name": "vitepress-carbon",
  "version": "1.6.0",
  "description": "Theme for VitePress documentation.",
  "keywords": [
    "design-system",
    "vue"
  ],
  "homepage": "https://github.com/brenoepics/vitepress-carbon#readme",
  "bugs": {
    "url": "https://github.com/brenoepics/vitepress-carbon/issues"
  },
  "license": "MIT",
  "author": "Breno A.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brenoepics/vitepress-carbon.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json",
    "./config": {
      "types": "./dist/theme/config/baseConfig.d.ts",
      "default": "./dist/theme/config/baseConfig.js"
    },
    "./components": {
      "types": "./dist/theme/components/index.d.ts",
      "default": "./dist/theme/components/index.js"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf dist",
    "addAssets": "node scripts/copyTheme.js && node scripts/generateComponentExports.js",
    "build": "pnpm clean && vue-tsc --noEmit -p ./ && tsc -p ./ && pnpm addAssets",
    "prepack": "pnpm build",
    "release": "pnpm build && npm publish"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@docsearch/css": "^4.6.0",
    "@docsearch/js": "^4.6.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "body-scroll-lock": "^3.1.5",
    "fs-extra": "^11.3.4",
    "markdown-it": "^14.1.1",
    "minisearch": "^7.2.0",
    "normalize.css": "^8.0.1",
    "tinyglobby": "^0.2.16",
    "vitepress-plugin-llms": "^1.12.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  },
  "devDependencies": {
    "@mdit-vue/types": "^3.0.2",
    "@types/body-scroll-lock": "^3.1.2",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "markdown-it-mathjax3": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "markdown-it-mathjax3": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.9.0"
}
